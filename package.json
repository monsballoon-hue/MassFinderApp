{
  "name": "massfinder",
  "version": "3.0.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "description": "Catholic services directory PWA",
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js --watch",
    "schema": "node scripts/generate-schema.js",
    "validate": "npx ajv-cli validate --spec=draft7 -s parish_data.schema.json -d parish_data.json --errors=text --all-errors -c ajv-formats",
    "precommit": "npm run build && npm run schema && npm run validate",
    "prepare": "husky",
    "build:bible": "node scripts/build-bible-drb.js",
    "build:xrefs": "node scripts/build-xrefs.js",
    "build:litcal": "node scripts/build-litcal.js",
    "build:summa": "node scripts/build-summa.js",
    "build:data": "npm run build:bible && npm run build:xrefs && npm run build:litcal && npm run build:summa",
    "modernize:baltimore": "node scripts/modernize-baltimore.js"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.0",
    "esbuild": "^0.24.0",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@nozbe/microfuzz": "^1.0.0"
  }
}
